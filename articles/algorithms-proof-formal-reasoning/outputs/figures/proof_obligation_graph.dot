digraph proof_obligations {
  graph [rankdir="LR"];
  "alg_insertion_sort" [shape=box];
  "proof_insert_sorted" [label="proof_insert_sorted\nloop invariant"];
  "alg_insertion_sort" -> "proof_insert_sorted";
  "alg_binary_search" [shape=box];
